rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ── Yearbook graduate profiles (public gallery) ──
    match /students/{studentId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ── Event covers, GC committee, leader photos ──
    match /siteMedia/{slotId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ── Manager admin list ──
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ── Student photo upload counter (needs student login) ──
    match /photoUploadLimits/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
