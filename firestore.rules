rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Graduate profiles — public yearbook gallery
    match /students/{studentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Event covers, leader photos, GC committee images (Cloudinary URLs)
    match /siteMedia/{slotId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Manager accounts — self-bootstrap on first login, then admin-only changes
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // Student profile photo upload counter (max 4 per uid)
    match /photoUploadLimits/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.count == 1;
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.count <= 4;
    }
  }
}
